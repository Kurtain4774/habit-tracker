{
  "compilerOptions": {
    /* Language + runtime */
    "target": "ES2020",
    "lib": ["ES2020"],

    /* Module system (IMPORTANT) */
    "module": "CommonJS",
    "moduleResolution": "Node",

    /* Project structure */
    "rootDir": "src",
    "outDir": "dist",

    /* Node compatibility */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    /* Type safety */
    "strict": true,
    "skipLibCheck": true,

    /* Dev experience */
    "sourceMap": true,

    /* FIXES YOUR ERROR */
    "verbatimModuleSyntax": false
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
